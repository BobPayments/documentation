{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bob Payments",
  "description": "Documentação da API Bob Payments - Orquestrador de pagamentos PIX para criar cobranças, gerenciar clientes e receber notificações em tempo real.",
  "logo": {
    "light": "https://resend-attachments.s3.amazonaws.com/bbjVzq13Vc2xBio",
    "dark": "https://resend-attachments.s3.amazonaws.com/bbjVzq13Vc2xBio"
  },
  "favicon": "pages/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.payments.bob.company"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Criar conta",
      "href": "https://app.payments.bob.company/register"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Produto",
        "items": [
          { "label": "Dashboard", "href": "https://app.payments.bob.company" },
          { "label": "Preços", "href": "https://app.payments.bob.company/pricing" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "Documentação", "href": "/" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Buscar na documentação..."
  },
  "seo": {
    "indexing": "navigable"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "api": {
    "mdx": {
      "server": "https://api.payments.bob.company",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Introdução",
            "pages": [
              "pages/introduction",
              "pages/guides/environments",
              "pages/quickstart/authentication",
              "pages/guides/production"
            ]
          },
          {
            "group": "PIX",
            "pages": [
              "pages/api-reference/transactions",
              "pages/api-reference/create-pix",
              "pages/api-reference/check-status",
              "pages/api-reference/list-transactions",
              "pages/sandbox/simulate-payment"
            ]
          },
          {
            "group": "Clientes",
            "pages": [
              "pages/api-reference/customers",
              "pages/api-reference/create-customer",
              "pages/api-reference/get-customer",
              "pages/api-reference/list-customers"
            ]
          },
          {
            "group": "Links de Pagamento",
            "pages": [
              "pages/api-reference/payment-links"
            ]
          },
          {
            "group": "Loja",
            "pages": [
              "pages/api-reference/store",
              "pages/api-reference/get-store"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "pages/webhooks/overview",
              "pages/webhooks/events",
              "pages/webhooks/signature-verification"
            ]
          }
        ]
      },
      {
        "tab": "Referência da API",
        "openapi": "https://raw.githubusercontent.com/BobPayments/irvine-v1/main/openapi.yaml"
      }
    ]
  }
}
