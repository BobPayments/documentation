{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bob Payments",
  "description": "Documentação da API Bob Payments - Orquestrador de pagamentos PIX para criar cobranças, gerenciar clientes e receber notificações em tempo real.",
  "logo": {
    "light": "https://resend-attachments.s3.amazonaws.com/bbjVzq13Vc2xBio",
    "dark": "https://resend-attachments.s3.amazonaws.com/bbjVzq13Vc2xBio"
  },
  "favicon": "https://resend-attachments.s3.amazonaws.com/bbjVzq13Vc2xBio",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.payments.bob.company"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Criar conta",
      "href": "https://app.payments.bob.company/register"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Produto",
        "items": [
          { "label": "Dashboard", "href": "https://app.payments.bob.company" },
          { "label": "Preços", "href": "https://app.payments.bob.company/pricing" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "Documentação", "href": "/" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Buscar na documentação..."
  },
  "seo": {
    "indexing": "navigable"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "api": {
    "mdx": {
      "server": "https://api.payments.bob.company",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Introdução",
            "pages": [
              "pages/introduction",
              "pages/devmode",
              "pages/authentication",
              "pages/webhooks",
              "pages/production"
            ]
          },
          {
            "group": "PIX",
            "pages": [
              "pages/pix/reference",
              "pages/pix/create",
              "pages/pix/check-status",
              "pages/pix/list",
              "pages/pix/simulate-payment"
            ]
          },
          {
            "group": "Clientes",
            "pages": [
              "pages/customers/reference",
              "pages/customers/create",
              "pages/customers/get",
              "pages/customers/list",
              "pages/customers/lookup"
            ]
          },
          {
            "group": "Loja",
            "pages": [
              "pages/store/reference",
              "pages/store/get"
            ]
          }
        ]
      },
      {
        "tab": "Referência da API",
        "openapi": "openapi.yaml"
      }
    ]
  }
}
